IDD_ABOUTBOX DIALOGEX 0, 0, 271, 241
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About PATN"
FONT 8, "MS Sans Serif", 0, 0, 0x1
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,11,7,20,20
    LTEXT           "PATN SET_AT_RUNTIME",IDC_VERSION,40,7,132,8,SS_NOPREFIX
    LTEXT           "Copyright © 2001 - 2009 \r\nBlatant Fabrications Pty Ltd",
                    IDC_STATIC,39,32,132,26
    DEFPUSHBUTTON   "OK",IDOK,217,6,47,15,WS_GROUP
    LTEXT           "SET_AT_RUNTIME",IDC_LONGDATE,39,17,137,8
    LTEXT           "",IDC_DISTRIBUTION,39,64,203,8
    EDITTEXT        IDC_ABOUT_TEXT,10,96,254,140,ES_MULTILINE | 
                    ES_AUTOVSCROLL | ES_AUTOHSCROLL | ES_READONLY | NOT 
                    WS_BORDER | WS_VSCROLL,WS_EX_STATICEDGE
    LTEXT           "",IDC_DISTRIBUTION_ORG,39,74,203,8
END

IDD_ODBC_CON_VALUES DIALOG  0, 0, 190, 123
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "ODBC Connection"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,133,7,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,133,24,50,14
    LTEXT           "DSN",IDC_STATIC,18,17,16,8
    LTEXT           "column label",IDC_STATIC,7,33,43,8
    LTEXT           "row label",IDC_STATIC,13,46,31,8
    LTEXT           "data",IDC_STATIC,17,62,15,8
    EDITTEXT        IDC_DSN,52,16,61,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_COL_LABEL_FIELD,52,30,61,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_ROW_LABEL_FIELD,52,44,62,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_DATA_FIELD,52,59,62,12,ES_AUTOHSCROLL
    LTEXT           "Table name",IDC_STATIC,7,75,39,8
    EDITTEXT        IDC_TABLE_NAME,52,73,62,12,ES_AUTOHSCROLL
END

IDD_KWOPTIONS DIALOGEX 0, 0, 289, 154
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Kruskal-Wallis Statistic View Options"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    DEFPUSHBUTTON   "OK",IDOK,229,113,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,229,132,50,14
    EDITTEXT        IDC_NUMVISIBLE,213,32,40,15,ES_AUTOHSCROLL
    CONTROL         "Spin1",IDC_NUMVISIBLESPIN,"msctls_updown32",
                    UDS_SETBUDDYINT | UDS_AUTOBUDDY | UDS_ARROWKEYS | 
                    UDS_NOTHOUSANDS,268,32,11,15
    CONTROL         "Columns",IDC_RADIO1,"Button",BS_AUTORADIOBUTTON,6,20,43,
                    10
    CONTROL         "By Cutoff",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON,211,
                    55,45,10
    CONTROL         "Best",IDC_RADIO3,"Button",BS_AUTORADIOBUTTON,212,19,30,
                    10
    EDITTEXT        IDC_CUTOFF,213,68,40,15,ES_AUTOHSCROLL
    LISTBOX         IDC_COLUMNS,6,33,188,112,LBS_NOINTEGRALHEIGHT | 
                    LBS_EXTENDEDSEL | WS_VSCROLL | WS_TABSTOP
    LTEXT           "View in 3DGraph and Scatterplot:",IDC_STATIC,6,6,106,8
END

IDD_NEWDIALOG DIALOGEX 0, 0, 224, 73
STYLE DS_SETFONT | DS_MODALFRAME | DS_NOFAILCREATE | WS_POPUP | WS_VISIBLE | 
    WS_CAPTION | WS_SYSMENU
CAPTION "Progress"
FONT 8, "MS Sans Serif", 0, 0, 0x0
BEGIN
    CONTROL         "Progress1",IDC_PROGRESS,"msctls_progress32",0x1,7,22,
                    210,14
    EDITTEXT        IDC_LABEL,7,7,210,14,ES_AUTOHSCROLL | ES_READONLY | NOT 
                    WS_BORDER
    DEFPUSHBUTTON   "Cancel",IDC_CANCEL,87,52,50,14
END

IDD_EVALUATION DIALOG  0, 0, 192, 46
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Evaluation"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "Run",IDOK,135,7,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,135,25,50,14
    PUSHBUTTON      "Set Parameters",IDC_SETPARMS,7,14,116,14
END

IDD_EVALUATIONRECIPE DIALOG  0, 0, 338, 238
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME
CAPTION "Evaluation Recipe"
