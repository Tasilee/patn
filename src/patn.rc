IDR_TABLETABS MENU 
BEGIN
    POPUP " "
    BEGIN
        POPUP "Visible &decimals"
        BEGIN
            MENUITEM "&0",                          ID__VISIBLEDECIMALS_0
            MENUITEM "&1",                          ID__VISIBLEDECIMALS_1
            MENUITEM "&2",                          ID__VISIBLEDECIMALS_2
            MENUITEM "&3",                          ID__VISIBLEDECIMALS_3
            MENUITEM "&4",                          ID__VISIBLEDECIMALS_4
            MENUITEM "&5",                          ID__VISIBLEDECIMALS_5
            MENUITEM "&6",                          ID__VISIBLEDECIMALS_6
            MENUITEM "&7",                          ID__VISIBLEDECIMALS_7
