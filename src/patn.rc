IDR_MAINFRAME MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Import...\tCtrl+I",          ID_FILE_IMPORT
        MENUITEM "OD&BC Connection \tCtrl+B",   ID_FILE_ODBCCONNECTION
        MENUITEM SEPARATOR
        MENUITEM "P&rint Setup...",             ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "Recent File",                 ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Toolbar",                    ID_VIEW_TOOLBAR
        MENUITEM "&PATN Toolbar",               33030
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Help Topics",                ID_HELP_FINDER
        MENUITEM SEPARATOR
        MENUITEM "PATN Online",                 ID_HELP_PATNONLINE
        MENUITEM "Discussion Forum",            ID_HELP_DISCUSSIONFORUM
        MENUITEM SEPARATOR
        MENUITEM "&About PATN...",              ID_APP_ABOUT
    END
END

IDR_TABLETYPE MENU 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New\tCtrl+N",                ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Import...\tCtrl+I",          ID_FILE_IMPORT
        MENUITEM "OD&BC Connection \tCtrl+B",   ID_FILE_ODBCCONNECTION
        MENUITEM "Appen&d \tCtrl+A ",           ID_FILE_APPEND
        MENUITEM "&Close",                      ID_FILE_CLOSE
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "&Print...\tCtrl+P",           ID_FILE_PRINT
        MENUITEM "Print Pre&view",              ID_FILE_PRINT_PREVIEW
        MENUITEM "P&rint Setup...",             ID_FILE_PRINT_SETUP
        MENUITEM SEPARATOR
        MENUITEM "Recent File",                 ID_FILE_MRU_FILE1, GRAYED
        MENUITEM SEPARATOR
        POPUP "&Import Analysis Data"
        BEGIN
            MENUITEM "&Row Group Composition",      ID_FILE_LOAD_ROWAFFINITYVECTOR

            MENUITEM "&Column Group Composition",   ID_FILE_LOAD_COLUMNAFFINITYVECTOR

            MENUITEM "A Priori Row Group Composition", 
                                                    ID_IMPORT_APRIORIROWGROUPCOMPOSITION

            MENUITEM "Row Dendrogram Order",        ID_IMPORTANALYSISDATA_ROWDENDOGRAMORDER

            MENUITEM "Column Dendrogram Order",     ID_IMPORTANALYSISDATA_COLUMNDENDOGRAMORDER

            MENUITEM "Row Lower-Symetric Association Matrix", 
                                                    ID_IMPORTANALYSISDATA_ROWLOWER

            MENUITEM "Column Lower-Symetric Association Matrix", 
                                                    ID_IMPORTANALYSISDATA_COLUMNLOWER

            MENUITEM "&Ordination Coordinates (Rows Only)", 
                                                    ID_FILE_LOAD_ORDINATION
        END
        POPUP "&Export Data Table"
        BEGIN
            MENUITEM "Data",                        ID_FILE_EXPORT_TABLEANDINFOTABS

            MENUITEM "Site Count",                  ID_FILE_EXPORT_SITECOUNT
        END
        POPUP "Export Analysis Data"
        BEGIN
            MENUITEM "Row Assocation Matrix",       ID_FILE_EXPORT_ROWASSOCATIONMATRIX

            MENUITEM "Column Association Matrix",   ID_FILE_EXPORT_COLUMNASSOCIATIONMATRIX

            MENUITEM "Row Group Composition",       ID_FILE_EXPORT_ROWAFFINITYVECTOR

            MENUITEM "Column Group Composition",    ID_FILE_EXPORT_COLUMNAFFINITYVECTOR

            MENUITEM "Row Fusion Table",            ID_FILE_EXPORT_ROWFUSIONTABLE

            MENUITEM "Column Fusion Table",         ID_FILE_EXPORT_COLUMNFUSIONTABLE

            MENUITEM "Ordination Coordinates",      ID_FILE_EXPORT_ORDINATIONCOORDINATES

        END
        POPUP "Export Evaluation Data"
        BEGIN
            MENUITEM "Row Group Statistics",        ID_FILE_EXPORT_GROUPSTATISTICS

            MENUITEM "Column Group Statistics",     ID_EXPORTEVALUATIONDATA_COLUMNGROUPSTATISTICS

            MENUITEM "Row ANOSIM Results",          ID_FILE_EXPORT_ROWANISMRESULTS

            MENUITEM "Column ANOSIM Results",       ID_FILE_EXPORT_COLUMNANISMRESULTS

            MENUITEM "Kruskal-Wallis Stats",        ID_FILE_EXPORT_KRUSKALWALLICESTATS

            MENUITEM "PCC Results",                 ID_FILE_EXPORT_PCCRESULTS

            MENUITEM "MCAO Results",                ID_FILE_EXPORT_MCAORESULTS

        END
        MENUITEM "Export History",              ID_FILE_EXPORT_HISTORY
        MENUITEM SEPARATOR
        MENUITEM "Check for &Update",           33043
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "View"
    BEGIN
        MENUITEM "Standard &Toolbar",           ID_VIEW_TOOLBAR
        MENUITEM "&PATN Toolbar",               ID_VIEW_PATNTOOLBAR
        MENUITEM "&Status Bar",                 ID_VIEW_STATUS_BAR
        MENUITEM SEPARATOR
        MENUITEM "D&ata Table",                 ID_SHOWTABLE
        MENUITEM "&Histograms",                 ID_VIEW_HISTOGRAM
        MENUITEM "Scatter Plot",                ID_VIEW_SCATTERPLOT33034
        MENUITEM SEPARATOR
        MENUITEM "&Association",                ID_VIEW_ASSOCIATIONMATRIX
        MENUITEM "&Dendrograms",                ID_VIEW_FUSIONDETAILS
        MENUITEM "T&wo-way Table",              ID_VIEW_TWAYTABLE
        MENUITEM "&Ordination Plot",            ID_VIEW_3DGRAPH_DIRECTX70A
        MENUITEM SEPARATOR
        MENUITEM "ANOSIM &Results",             ID_VIEW_ANOSIMRESULTS
        MENUITEM "&Box-Whisker",                ID_VIEW_BOXWHISKERSTATISTICS
        MENUITEM "Constancy && Fidelity",       ID_VIEW_CONSTFID
        MENUITEM "P&CC Results",                ID_VIEW_PCCRESULTS
        MENUITEM "&MCAO Results",               ID_VIEW_MCAO
        MENUITEM SEPARATOR
        MENUITEM "Histor&y",                    ID_VIEW_HISTORY
    END
    POPUP "&Data"
    BEGIN
        MENUITEM "&Transformation",             ID_TOOLS_DATATRANSFORMATION
        MENUITEM "&Analysis",                   ID_TOOLS_DATAANALYSIS
        MENUITEM "&Evaluation",                 ID_TOOLS_DATAEVALUATION
        MENUITEM SEPARATOR
        MENUITEM "&Selection Options",          ID_TABLE_SELECTIONOPTIONS
        MENUITEM "Delete Duplicate Rows",       33045
        MENUITEM "T&ranspose",                  ID_TABLE_TANSPOSEDATALABELS
        MENUITEM "Create new variables from variable groups", 
                                                ID_DATA_CREATENEWVARIABLESREPRESENTINGGROUPS

        MENUITEM "Swap Row Intrinsics with Extrinsics", 
                                                ID_DATA_SWAPROWINTRINSICSWITHEXTRINSICS

        MENUITEM "Swap Column Intrinsics with Extrinsics", 
                                                ID_DATA_SWAPCOLUMNINTRINSICSWITHEXTRINSICS

        MENUITEM "Variables < KW threashold to Extrinsics", 
                                                ID_DATA_VARIABLES_KW_TO_EXTRINSICS

        MENUITEM "Assign Groups to non-grouped rows", 
                                                ID_DATA_ASSIGNGROUPSTONON
        MENUITEM SEPARATOR
        POPUP "&Row"
        BEGIN
            MENUITEM "&Select",                     ID_TABLE_ROW_SELECT
            MENUITEM SEPARATOR
            MENUITEM "&Hide",                       ID_TABLE_ROW_HIDE
            MENUITEM "&Unhide",                     ID_TABLE_ROW_UNHIDE
            MENUITEM SEPARATOR
            MENUITEM "&Add",                        ID_TABLE_ROW_ADD
            MENUITEM "&Insert",                     ID_TABLE_ROW_INSERT
            MENUITEM "&Delete",                     ID_TABLE_ROW_DELETE
            MENUITEM SEPARATOR
            MENUITEM "Make Extrinsic",              ID_TABLE_ROW_MAKEEXTRINSIC

            MENUITEM "Make Intrinsic",              ID_TABLE_ROW_MAKEINTRINSIC

            MENUITEM "Go To Extrinsics",            ID_TABLE_ROW_GOTOEXTRINSICS

            MENUITEM SEPARATOR
            MENUITEM "&Groups",                     ID_TABLE_ROW_GROUPS
            MENUITEM "&a priori Groups",            ID_DATA_CONTROLGROUPS
            MENUITEM SEPARATOR
            MENUITEM "&Properties",                 ID_TABLE_ROW_PROPERTIES
        END
        POPUP "&Column"
        BEGIN
            MENUITEM "&Select",                     ID_TABLE_COLUMN_SELECT
            MENUITEM SEPARATOR
            MENUITEM "&Hide",                       ID_TABLE_COLUMN_HIDE
            MENUITEM "&Unhide",                     ID_TABLE_COLUMN_UNHIDE
            MENUITEM SEPARATOR
            MENUITEM "&Add",                        ID_TABLE_COLUMN_ADD
            MENUITEM "&Insert",                     ID_TABLE_COLUMN_INSERT
            MENUITEM "&Delete",                     ID_TABLE_COLUMN_DELETE
            MENUITEM SEPARATOR
            MENUITEM "Make Extrinsic",              ID_TABLE_COLUMN_MAKEEXTRINSIC

            MENUITEM "Make Intrinsic",              ID_TABLE_COLUMN_MAKEINTRINSIC

            MENUITEM "Go To Extrinsics",            ID_TABLE_COLUMN_GOTOEXTRINSICS

            MENUITEM SEPARATOR
            MENUITEM "&Groups",                     ID_TABLE_COLUMN_GROUPS
            MENUITEM SEPARATOR
            MENUITEM "&Properties",                 ID_TABLE_COLUMN_PROPERTIES

        END
    END
    POPUP "&Tools"
    BEGIN
        MENUITEM "&Options",                    ID_TOOLS_OPTIONS
    END
    POPUP "&Window"
    BEGIN
        MENUITEM "&Cascade",                    ID_WINDOW_CASCADE
        MENUITEM "&Tile",                       ID_WINDOW_TILE_HORZ
        MENUITEM "&Arrange Icons",              ID_WINDOW_ARRANGE
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&Help Topics",                ID_HELP_FINDER
        MENUITEM SEPARATOR
        MENUITEM "PATN Online",                 33032
        MENUITEM "Discussion Forum",            33033
        MENUITEM SEPARATOR
        MENUITEM "&About PATN...",              ID_APP_ABOUT
    END
    POPUP "Selections"
    BEGIN
        MENUITEM "Clear",                       ID_SELECTIONS_CLEAR
        POPUP "Selection 1"
        BEGIN
            MENUITEM "Activate",                    ID_SELECTION1_ACTIVATE
            MENUITEM "Save Current Selection",      ID_SELECTION1_SAVECURRENTSELECTION

        END
        POPUP "Seleciton 2"
        BEGIN
            MENUITEM "Activate",                    ID_SELECTION2_ACTIVATE
            MENUITEM "Save Current Selection",      ID_SELECTION2_SAVECURRENTSELECTION

        END
        POPUP "Selection 3"
        BEGIN
            MENUITEM "Activate",                    ID_SELECTION3_ACTIVATE
            MENUITEM "Save Current Selection",      ID_SELECTION3_SAVECURRENTSELECTION

        END
        POPUP "Selection 4"
        BEGIN
            MENUITEM "Activate",                    ID_SELECTION4_ACTIVATE
            MENUITEM "Save Current Selection",      ID_SELECTION4_SAVECURRENTSELECTION

        END
        POPUP "Selection 5"
        BEGIN
            MENUITEM "Activate",                    ID_SELECTION5_ACTIVATE
            MENUITEM "Save Current Selection",      ID_SELECTION5_SAVECURRENTSELECTION

        END
        POPUP "Selection 6"
        BEGIN
            MENUITEM "Activate",                    ID_SELECTION6_ACTIVATE
            MENUITEM "Save Current Selection",      ID_SELECTION6_SAVECURRENTSELECTION

        END
    END
END


