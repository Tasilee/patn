IDR_MENU_COLUMN MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "&Hide",                       ID_TABLE_COLUMN_HIDE
        MENUITEM "&Unhide",                     ID_TABLE_COLUMN_UNHIDE
        MENUITEM SEPARATOR
        MENUITEM "&Add",                        ID_TABLE_COLUMN_ADD
        MENUITEM "&Insert",                     ID_TABLE_COLUMN_INSERT
        MENUITEM "&Delete",                     ID_TABLE_COLUMN_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Make &extrinsic",             ID_TABLE_COLUMN_MAKEEXTRINSIC

        MENUITEM "Make i&ntrinsic",             ID_TABLE_COLUMN_MAKEINTRINSIC

        MENUITEM SEPARATOR
        MENUITEM "&Properties...",              ID_TABLE_COLUMN_PROPERTIES
    END
END

IDR_MENU_ROW MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "&Hide",                       ID_TABLE_ROW_HIDE
        MENUITEM "&Unhide",                     ID_TABLE_ROW_UNHIDE
        MENUITEM SEPARATOR
        MENUITEM "&Add",                        ID_TABLE_ROW_ADD
        MENUITEM "&Insert",                     ID_TABLE_ROW_INSERT
        MENUITEM "&Delete",                     ID_TABLE_ROW_DELETE
        MENUITEM SEPARATOR
        MENUITEM "Make extrinsic",              ID_TABLE_ROW_MAKEEXTRINSIC
        MENUITEM "Make intrinsic",              ID_TABLE_ROW_MAKEINTRINSIC
        MENUITEM SEPARATOR
        MENUITEM "&Properties...",              ID_TABLE_ROW_PROPERTIES
    END
END

IDR_MENU_3DVIEW MENU 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "Rotate\tspace",               ID__ROTATE
        MENUITEM "Speed up\t->",                ID__PLUSROTATIONSPEED
        MENUITEM "Slow down\t<-",               ID__MINUSROTATIONSPEED
        POPUP "Set rotation"
        BEGIN
            MENUITEM "Reset rotation",              ID__RESETROTATION
            MENUITEM "View axies 1 and 2",          ID__SETROTATION_VIEWXY
            MENUITEM "View axies 2 and 3",          ID__SETROTATION_VIEWYZ
            MENUITEM "View axies 1 and 3",          ID__SETROTATION_VIEWXZ
        END
        MENUITEM SEPARATOR
        MENUITEM "Display legend\td",           ID__DISPLAYLEGEND
        MENUITEM "Display ranges\tr",           ID__SHOWRANGES
        MENUITEM "Add text box...",             ID__ADDTEXTBOX
        MENUITEM "Alter font...",               ID__FONT
        MENUITEM "Alter object size...",        ID__OBJECTSIZE
        POPUP "Object size"
        BEGIN
            MENUITEM "Increase \tPgUp",             ID_SYMBOLSIZE_INCREASEPGUP

            MENUITEM "Decrease\tPgDn",              ID_SYMBOLSIZE_DECREASEPGDN

        END
        MENUITEM SEPARATOR
        MENUITEM "Display labels\tl",           ID__DISPLAYLABELS
        MENUITEM "Display B && W symbols \tb",  ID__USEBLACKWHITESYMBOLS
        MENUITEM "Display selected \to",        ID__SHOWSELECTEDONLY
        MENUITEM SEPARATOR
        POPUP "Group centroid type"
        BEGIN
            MENUITEM "Analysis groups and centroids\tt", 
                                                    ID_GROUP_ANALYSISGROUPSANDCENTROIDS
            , CHECKED
            MENUITEM "A priori groups and centroids\tt", 
                                                    ID_GROUP_APRIORIGROUPSANDCENTROIDS

        END
        MENUITEM "Display centroid colours\tg", ID__SHOWGROUPING
        MENUITEM "Display user colours\tu",     ID__USEUSERGROUPCOLOURS
        MENUITEM "Colour by column...\tp",      ID__PICKACOLUMN
        MENUITEM "Display group centroids\tc",  ID__DISPLAYCENTROIDS
        MENUITEM SEPARATOR
        MENUITEM "Display data variables...",   ID__SELECTPCCVECTORS
        MENUITEM "Display MST\tm",              ID__DISPLAYMST
        MENUITEM SEPARATOR
        MENUITEM "Print preview",               ID__PRINTPREVIEW
        MENUITEM "Print...",                    ID__PRINT
        MENUITEM "Save image...",               ID__SAVEIMAGE
        MENUITEM "Save video...",               ID__SAVEVIDEO
        MENUITEM SEPARATOR
        MENUITEM "Close",                       ID__CLOSE
    END
END

