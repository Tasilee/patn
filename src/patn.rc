BEGIN
    EDITTEXT        IDC_EDIT_MISSING_VALUE,15,21,40,14,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDIT_NUM_ROWS,78,60,26,14,ES_AUTOHSCROLL
    EDITTEXT        IDC_EDIT_NUM_COLUMNS,180,60,26,14,ES_AUTOHSCROLL
