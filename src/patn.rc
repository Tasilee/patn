                    UDS_NOTHOUSANDS,181,186,11,14
    LTEXT           "Number of rows:",IDC_STATIC,22,62,52,8
    LTEXT           "Number of decimal places to display:",IDC_STATIC,139,
                    164,68,20
    GROUPBOX        "Initialise cells with: ",IDC_STATIC,7,135,103,90
    LTEXT           "Number of columns:",IDC_STATIC,112,62,64,8
    GROUPBOX        "Table size",IDC_STATIC,7,46,215,35
    GROUPBOX        "Decimal places",IDC_STATIC,119,135,103,90
    GROUPBOX        "Initial column width",IDC_STATIC,7,86,215,43
    GROUPBOX        "Missing value",IDC_STATIC,7,7,215,35
