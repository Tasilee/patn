                    WS_GROUP | WS_TABSTOP,24,100,80,10
    CONTROL         "Custom width - specify:",IDC_RADIO_CUSTOM,"Button",
                    BS_AUTORADIOBUTTON | WS_TABSTOP,24,113,87,10
    EDITTEXT        IDC_EDIT_COLUMN_WIDTH,121,110,26,14,ES_AUTOHSCROLL
    CONTROL         "Zero value",IDC_RADIO_INIT_CELLS,"Button",
                    BS_AUTORADIOBUTTON | WS_GROUP,22,146,50,10
    CONTROL         "Missing data value",IDC_RADIO2,"Button",
                    BS_AUTORADIOBUTTON,22,158,75,10
    CONTROL         "Random values",IDC_RADIO3,"Button",BS_AUTORADIOBUTTON,
                    22,170,65,10
